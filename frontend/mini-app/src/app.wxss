/* ============================================
   GWP小店 - 全局样式
   ============================================ */

/* 主题色 */
page {
  --primary-color: #07c160;
  --primary-light: #f0f9f4;
  --danger-color: #ff4d4f;
  --warning-color: #faad14;
  --gray-color: #999999;
  --light-gray: #f5f5f5;
  --border-color: #eeeeee;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--light-gray);
}

/* 通用容器 */
.container {
  min-height: 100vh;
  background-color: var(--light-gray);
}

.page-content {
  padding: 24rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 按钮样式 */
.btn-primary {
  background-color: var(--primary-color);
  color: #ffffff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-primary.button-hover {
  opacity: 0.85;
}

.btn-secondary {
  background-color: #ffffff;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

.btn-disabled {
  background-color: #cccccc;
  color: #ffffff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
}

/* 价格样式 */
.price {
  color: var(--danger-color);
  font-size: 32rpx;
  font-weight: 600;
}

.price-small {
  color: var(--danger-color);
  font-size: 24rpx;
}

.price-original {
  color: var(--text-muted);
  text-decoration: line-through;
  font-size: 24rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-green {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.tag-red {
  background-color: #fff1f0;
  color: var(--danger-color);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-state text {
  color: var(--text-muted);
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 24rpx 0;
}

/* Flex工具 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

/* 文字省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 24rpx 0;
  color: var(--text-muted);
  font-size: 24rpx;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

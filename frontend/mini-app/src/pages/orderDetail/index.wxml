<!-- pages/orderDetail/index.wxml -->
<view class="page">
  <!-- 收货地址 -->
  <view class="address-section" bindtap="goSelectAddress">
    <view wx:if="{{address}}" class="address-info">
      <view class="address-name">{{address.name}}  {{address.phone}}</view>
      <view class="address-detail">{{address.province}}{{address.city}}{{address.district}}{{address.detail}}</view>
    </view>
    <view wx:else class="address-empty">请选择收货地址</view>
    <text class="arrow">></text>
  </view>
  
  <!-- 商品列表 -->
  <view class="goods-section card">
    <view wx:for="{{items}}" wx:key="id" class="goods-item">
      <image src="{{item.product.main_image}}" class="goods-image" />
      <view class="goods-info">
        <text class="goods-name text-ellipsis-2">{{item.product.name}}</text>
        <view class="goods-bottom">
          <text class="price">¥{{item.product.price}}</text>
          <text class="goods-qty">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 礼盒包装 -->
  <view class="option-row card">
    <text class="option-label">礼盒包装</text>
    <switch checked="{{giftPackage}}" bindchange="toggleGiftPackage" color="#07c160" />
  </view>
  
  <!-- 贺卡留言 -->
  <view class="input-row card">
    <text class="input-label">贺卡留言</text>
    <input class="input-field" placeholder="写下您的祝福(选填)" value="{{greetingCard}}" bindinput="onGreetingInput" maxlength="100" />
  </view>
  
  <!-- 备注 -->
  <view class="input-row card">
    <text class="input-label">备注</text>
    <input class="input-field" placeholder="备注信息(选填)" value="{{remark}}" bindinput="onRemarkInput" maxlength="200" />
  </view>
  
  <!-- 价格明细 -->
  <view class="price-detail card">
    <view class="price-row">
      <text>商品总价</text>
      <text>¥{{totalAmount}}</text>
    </view>
    <view class="price-row" wx:if="{{giftPackage}}">
      <text>礼盒包装</text>
      <text>+¥10.00</text>
    </view>
    <view class="price-row">
      <text>运费</text>
      <text>包邮</text>
    </view>
  </view>
  
  <!-- 底部提交栏 -->
  <view class="submit-bar safe-area-bottom">
    <view class="submit-left">
      <text class="submit-label">实付款</text>
      <text class="price price-large">¥{{payAmount}}</text>
    </view>
    <button class="btn-primary submit-btn" bindtap="onSubmit" loading="{{loading}}">
      提交订单
    </button>
  </view>
</view>

<!-- pages/order/index.wxml -->
<view class="page">
  <!-- 状态 Tab -->
  <scroll-view class="status-tabs" scroll-x>
    <view wx:for="{{tabs}}" wx:key="key" 
      class="tab-item {{activeTab === index ? 'active' : ''}}"
      bindtap="switchTab" data-index="{{index}}">
      {{item.label}}
    </view>
  </scroll-view>
  
  <!-- 订单列表 -->
  <view class="order-list">
    <view wx:for="{{orders}}" wx:key="id" class="order-card card" bindtap="goDetail" data-orderno="{{item.order_no}}">
      <view class="order-header">
        <text class="order-no">订单号: {{item.order_no}}</text>
        <text class="tag {{getStatusClass(item.status)}}">{{getStatusName(item.status)}}</text>
      </view>
      <view class="order-items">
        <view wx:for="{{item.items}}" wx:key="id" wx:for-item="orderItem" class="order-item">
          <image src="{{orderItem.product_image}}" class="item-image" />
          <view class="item-info">
            <text class="item-name text-ellipsis-2">{{orderItem.product_name}}</text>
            <text class="item-qty">x{{orderItem.quantity}}</text>
          </view>
          <text class="item-price">¥{{orderItem.price}}</text>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-time">{{item.created_at}}</text>
        <view class="order-total">
          <text>共{{item.items.length}}件  实付</text>
          <text class="price">¥{{item.pay_amount}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && orders.length === 0}}">
    <image src="/assets/icons/empty-order.png" />
    <text>暂无订单</text>
  </view>
  
  <!-- 加载更多 -->
  <view class="loading-more" wx:if="{{loading}}"><text>加载中...</text></view>
  <view class="loading-more" wx:if="{{!hasMore && orders.length > 0}}"><text>没有更多了</text></view>
</view>

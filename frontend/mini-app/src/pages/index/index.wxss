/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin: 20rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  opacity: 0.6;
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
}

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 320rpx;
  margin-bottom: 20rpx;
}

.banner-item {
  width: 100%;
  height: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.banner-text {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

/* 生长状态 Banner */
.growth-banner {
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 12rpx;
  border-left: 6rpx solid #07c160;
}

.growth-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2e7d32;
  margin-bottom: 8rpx;
}

.growth-content {
  font-size: 24rpx;
  color: #388e3c;
  line-height: 1.6;
}

/* 分类导航 */
.category-scroll {
  white-space: nowrap;
  padding: 0 24rpx 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.category-list {
  display: flex;
  gap: 32rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  padding: 16rpx 0;
}

.category-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.category-item text {
  font-size: 24rpx;
  color: #666;
}

.category-item.active text {
  color: #07c160;
  font-weight: 500;
}

/* 商品网格 */
.product-grid {
  padding: 0 24rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.product-item {
  width: 100%;
}

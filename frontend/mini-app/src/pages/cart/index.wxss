/* pages/cart/index.wxss */

.address-bar {
  display: flex;
  align-items: center;
  min-height: 120rpx;
  margin: 0;
  border-radius: 0;
  border-bottom: 1rpx solid var(--border-color);
}

.address-info {
  flex: 1;
}

.address-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.address-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.address-empty {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--text-muted);
}

/* 购物车项 */
.cart-item {
  display: flex;
  align-items: center;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  position: relative;
}

.cart-select {
  padding: 16rpx;
  margin-right: 8rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--gray-color);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkbox.checked {
  background-color: var(--primary-color);
  border-color: var(--primary-color);
}

.checkbox.checked::after {
  content: '✓';
  color: #fff;
  font-size: 24rpx;
}

.cart-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background-color: var(--light-gray);
  margin-right: 20rpx;
}

.cart-info {
  flex: 1;
  min-width: 0;
}

.cart-name {
  font-size: 28rpx;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.cart-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-secondary);
}

.qty-num {
  width: 64rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 删除按钮 */
.cart-delete {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gray-color);
  font-size: 36rpx;
}

/* 结算栏 */
.checkout-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  border-top: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.checkout-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
}

.checkout-center {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 8rpx;
  margin-right: 24rpx;
}

.total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.total-price {
  font-size: 40rpx;
}

.checkout-btn {
  height: 80rpx !important;
  line-height: 80rpx !important;
  font-size: 30rpx !important;
  padding: 0 48rpx !important;
  border-radius: 40rpx !important;
}

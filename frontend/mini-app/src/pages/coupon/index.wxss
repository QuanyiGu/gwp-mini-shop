/* pages/coupon/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 标签栏 */
.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #ff6b35;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #ff6b35;
  border-radius: 2rpx;
}

/* 领取按钮 */
.receive-btn {
  margin: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5a);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 53, 0.3);
}

.receive-btn .icon {
  font-size: 36rpx;
  margin-right: 8rpx;
  font-weight: bold;
}

/* 优惠券列表 */
.coupon-list {
  padding: 0 24rpx;
}

.coupon-item {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.coupon-item:active {
  transform: scale(0.98);
}

.coupon-item.disabled {
  opacity: 0.6;
}

.coupon-item.disabled:active {
  transform: none;
}

/* 左侧金额区域 */
.coupon-left {
  width: 200rpx;
  padding: 32rpx 16rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5a);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  position: relative;
}

.coupon-item.disabled .coupon-left {
  background: linear-gradient(135deg, #ccc, #bbb);
}

.amount {
  display: flex;
  align-items: baseline;
}

.amount .symbol {
  font-size: 28rpx;
  margin-right: 4rpx;
}

.amount .value {
  font-size: 56rpx;
  font-weight: bold;
  line-height: 1;
}

.condition {
  font-size: 22rpx;
  margin-top: 8rpx;
  opacity: 0.9;
}

/* 分割线 */
.coupon-divider {
  width: 32rpx;
  position: relative;
  background-color: #fff;
}

.coupon-divider .circle {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.coupon-divider .circle.top {
  top: -12rpx;
}

.coupon-divider .circle.bottom {
  bottom: -12rpx;
}

.coupon-divider .line {
  position: absolute;
  top: 20rpx;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  border-left: 2rpx dashed #ddd;
}

/* 右侧信息区域 */
.coupon-right {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.coupon-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.coupon-time {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.coupon-status {
  align-self: flex-end;
}

.status-usable {
  font-size: 24rpx;
  color: #ff6b35;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ff6b35;
  border-radius: 24rpx;
}

.status-used,
.status-expired {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 24rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5a);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.empty-btn::after {
  border: none;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 80rpx;
  font-size: 28rpx;
  color: #999;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-title {
  padding: 32rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 40rpx 32rpx;
}

.code-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.code-input:focus {
  border-color: #ff6b35;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
  background: none;
  border-radius: 0;
  line-height: 1.5;
}

.btn::after {
  border: none;
}

.btn-cancel {
  color: #666;
  border-right: 1rpx solid #eee;
}

.btn-confirm {
  color: #ff6b35;
  font-weight: 500;
}

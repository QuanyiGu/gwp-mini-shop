<view class="empty-state">
  <image class="empty-icon" src="{{icon}}" mode="aspectFit" wx:if="{{icon}}" />
  <view class="empty-icon-placeholder" wx:else>
    <text class="placeholder-text">{{emoji || '📭'}}</text>
  </view>
  <text class="empty-text">{{text || '暂无数据'}}</text>
  <view class="empty-action" wx:if="{{actionText}}" bindtap="onAction">
    <text class="action-text">{{actionText}}</text>
  </view>
</view>

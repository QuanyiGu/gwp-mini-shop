# GWP小店 后端环境配置

# 数据库配置
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=gwp_shop
DB_CHARSET=utf8mb4
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# 测试数据库（SQLite）
TEST_DB_URL=sqlite+aiosqlite:///./test_gwp.db

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET_KEY=gwp-shop-jwt-secret-key-2026-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 微信小程序配置
WX_APPID=your_appid_here
WX_SECRET=your_secret_here

# 微信支付配置
WX_PAY_MCH_ID=your_mch_id_here
WX_PAY_KEY=your_pay_key_here
WX_PAY_NOTIFY_URL=https://api.gwp-shop.com/api/pay/notify
WX_PAY_SPBILL_IP=127.0.0.1

# Celery配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 雪花算法配置
SNOWFLAKE_EPOCH=1577836800000
SNOWFLAKE_MACHINE_ID=1
